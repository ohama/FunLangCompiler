// --- Command: bash -c 'OUTBIN=$(mktemp /tmp/langback_XXXXXX) && dotnet run --project %S/../../src/LangBackend.Cli/LangBackend.Cli.fsproj -- %input -o $OUTBIN && $OUTBIN; echo $?; rm -f $OUTBIN'
// --- Input:
let ht = hashtable_create () in
let _ = hashtable_set ht 10 100 in
let _ = hashtable_set ht 20 200 in
let _ = hashtable_set ht 30 300 in
let _ = hashtable_remove ht 20 in
let keys = hashtable_keys ht in
let rec len lst =
  match lst with
  | [] -> 0
  | _ :: t -> 1 + len t
in
len keys
// --- Output:
2
