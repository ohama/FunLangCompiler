// --- Input:
module Char =
    let isDigit c = char_is_digit c
    let toUpper c = char_to_upper c
    let isLetter c = char_is_letter c
    let isUpper c = char_is_upper c
    let isLower c = char_is_lower c
    let toLower c = char_to_lower c
    let toInt c = char_to_int c
    let ofInt n = int_to_char n
let _ = println (to_string (Char.isDigit '5'))
let _ = println (to_string (Char.isLetter 'a'))
let _ = println (to_string (Char.isUpper 'A'))
let _ = println (to_string (Char.isLower 'a'))
let _ = println (to_string (Char.toInt 'A'))
let _ = println (to_string (Char.ofInt 66))
// --- Output:
true
true
true
true
65
66
0
