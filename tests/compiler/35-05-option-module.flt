// --- Command: bash -c 'OUTBIN=$(mktemp /tmp/fnc_XXXXXX) && dotnet run --project %S/../../src/FunLangCompiler.Cli/FunLangCompiler.Cli.fsproj -- %input -o $OUTBIN && $OUTBIN; echo $?; rm -f $OUTBIN'
// --- Input:
module Option =
    type Option 'a = None | Some of 'a
    let map f opt = match opt with | Some x -> Some (f x) | None -> None
    let bind f opt = match opt with | Some x -> f x | None -> None
    let defaultValue def opt = match opt with | Some x -> x | None -> def
    let iter f opt = match opt with | Some x -> f x | None -> ()
    let filter pred opt = match opt with | Some x -> if pred x then Some x else None | None -> None
    let isSome opt = match opt with | Some _ -> true | None -> false
    let isNone opt = match opt with | Some _ -> false | None -> true
let optGet opt = match opt with | Some v -> v | None -> -1
let mapped = Option.map (fun x -> x + 1) (Some 10) in
let bound = Option.bind (fun x -> if x > 5 then Some (x * 2) else None) (Some 10) in
let def42 = Option.defaultValue 0 (Some 42) in
let def0 = Option.defaultValue 0 None in
let is_some = (Option.isSome (Some 1)) <> 0 in
let is_none = (Option.isNone None) <> 0 in
let mv = optGet mapped in
let bv = optGet bound in
let _ = println (to_string mv) in
let _ = println (to_string bv) in
let _ = println (to_string def42) in
let _ = println (to_string def0) in
let _ = println (to_string is_some) in
println (to_string is_none)
// --- Output:
11
20
42
0
true
true
0
