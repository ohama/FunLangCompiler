// --- Command: bash -c 'OUTBIN=$(mktemp /tmp/fnc_XXXXXX) && dotnet run --project %S/../../src/FunLangCompiler.Cli/FunLangCompiler.Cli.fsproj -- %input -o $OUTBIN && $OUTBIN; echo $?; rm -f $OUTBIN'
// --- Input:
module MyOption =
    type MyOpt 'a = MyNone | MyJust of 'a
    let map f opt = match opt with | MyJust x -> MyJust (f x) | MyNone -> MyNone
    let bind f opt = match opt with | MyJust x -> f x | MyNone -> MyNone
    let defaultValue def opt = match opt with | MyJust x -> x | MyNone -> def
    let iter f opt = match opt with | MyJust x -> f x | MyNone -> ()
    let filter pred opt = match opt with | MyJust x -> if pred x then MyJust x else MyNone | MyNone -> MyNone
    let isSome opt = match opt with | MyJust _ -> true | MyNone -> false
    let isNone opt = match opt with | MyJust _ -> false | MyNone -> true
let optGet opt = match opt with | MyJust v -> v | MyNone -> -1
let mapped = MyOption.map (fun x -> x + 1) (MyJust 10) in
let bound = MyOption.bind (fun x -> if x > 5 then MyJust (x * 2) else MyNone) (MyJust 10) in
let def42 = MyOption.defaultValue 0 (MyJust 42) in
let def0 = MyOption.defaultValue 0 MyNone in
let is_some = (MyOption.isSome (MyJust 1)) <> 0 in
let is_none = (MyOption.isNone MyNone) <> 0 in
let mv = optGet mapped in
let bv = optGet bound in
let _ = println (to_string mv) in
let _ = println (to_string bv) in
let _ = println (to_string def42) in
let _ = println (to_string def0) in
let _ = println (to_string is_some) in
println (to_string is_none)
// --- Output:
11
20
42
0
true
true
0
