// --- Command: bash -c 'OUTBIN=$(mktemp /tmp/fnc_XXXXXX) && dotnet run --project %S/../../src/FunLangCompiler.Cli/FunLangCompiler.Cli.fsproj -- %input -o $OUTBIN && $OUTBIN; echo $?; rm -f $OUTBIN'
// --- Input:
type MyOpt 'a = MyNone | MyJust of 'a
module MyResult =
    type MyRes 'a 'b = MyOk of 'a | MyErr of 'b
    let map f r = match r with | MyOk x -> MyOk (f x) | MyErr e -> MyErr e
    let bind f r = match r with | MyOk x -> f x | MyErr e -> MyErr e
    let mapError f r = match r with | MyOk x -> MyOk x | MyErr e -> MyErr (f e)
    let defaultValue def r = match r with | MyOk x -> x | MyErr _ -> def
    let toOption r = match r with | MyOk x -> MyJust x | MyErr _ -> MyNone
let okGet r = match r with | MyOk v -> v | MyErr _ -> -1
let optGet opt = match opt with | MyJust v -> v | MyNone -> -1
let mapped = MyResult.map (fun x -> x + 1) (MyOk 10) in
let bound = MyResult.bind (fun x -> MyOk (x * 2)) (MyOk 5) in
let def42 = MyResult.defaultValue 0 (MyOk 42) in
let def0 = MyResult.defaultValue 0 (MyErr "fail") in
let opt = MyResult.toOption (MyOk 99) in
let mv = okGet mapped in
let bv = okGet bound in
let ov = optGet opt in
let _ = println (to_string mv) in
let _ = println (to_string bv) in
let _ = println (to_string def42) in
let _ = println (to_string def0) in
let _ = println (to_string ov) in
0
