// --- Command: bash -c 'OUTBIN=$(mktemp /tmp/fnc_XXXXXX) && dotnet run --project %S/../../src/FunLangCompiler.Cli/FunLangCompiler.Cli.fsproj -- %input -o $OUTBIN && $OUTBIN; echo $?; rm -f $OUTBIN'
// --- Input:
let rec len lst =
  match lst with
  | [] -> 0
  | _ :: t -> 1 + len t
let ht = hashtable_create ()
let _ = hashtable_set ht "hello" 42
let v1 = hashtable_get ht "hello"
let _ = println (to_string v1)
let c1 = if hashtable_containsKey ht "hello" then 1 else 0
let _ = println (to_string c1)
let c2 = if hashtable_containsKey ht "world" then 1 else 0
let _ = println (to_string c2)
let _ = hashtable_set ht "world" 99
let n1 = hashtable_count ht
let _ = println (to_string n1)
let _ = hashtable_remove ht "hello"
let c3 = if hashtable_containsKey ht "hello" then 1 else 0
let _ = println (to_string c3)
let n2 = hashtable_count ht
let _ = println (to_string n2)
let ks = hashtable_keys ht
let klen = len ks
let _ = println (to_string klen)
// --- Output:
42
1
0
2
0
1
1
0
