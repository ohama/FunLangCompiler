// --- Command: bash -c 'OUTBIN=$(mktemp /tmp/langback_XXXXXX) && dotnet run --project %S/../../src/FunLangCompiler.Cli/FunLangCompiler.Cli.fsproj -- %input -o $OUTBIN && $OUTBIN; echo $?; rm -f $OUTBIN'
// --- Input:
let f x = if x = 0 then 10 else match x with | 1 -> 20 | _ -> 30
let _ = println (to_string (f 0))
let _ = println (to_string (f 1))
let _ = println (to_string (f 5))
let g x = if x = 0 then match x with | _ -> 100 else 200
let _ = println (to_string (g 0))
let _ = println (to_string (g 3))
let rec take n xs = if n = 0 then [] else match xs with | [] -> [] | h :: t -> h :: take (n - 1) t
let result = take 3 [10; 20; 30; 40; 50]
let rec print_list lst = match lst with | [] -> () | h :: t -> let _ = println (to_string h) in print_list t
let _ = print_list result
let _ = 0
// --- Output:
10
20
30
100
200
10
20
30
0