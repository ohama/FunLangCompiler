// Test: Return type annotations — let with return type (FunLang v8.0)
// --- Command: bash -c 'OUTBIN=$(mktemp /tmp/fnc_XXXXXX) && dotnet run --project %S/../../src/FunLangCompiler.Cli/FunLangCompiler.Cli.fsproj -- %input -o $OUTBIN && $OUTBIN; echo $?; rm -f $OUTBIN'
// --- Input:
let add x : int = x + 1
let f x y : int = x + y
let x : int = 42
let _ = println (to_string (add 41))
let _ = println (to_string (f 10 20))
let _ = println (to_string x)
// --- Output:
42
30
42
0
