// Test: Combined param + return type annotations (FunLang v8.0)
// --- Command: bash -c 'OUTBIN=$(mktemp /tmp/langback_XXXXXX) && dotnet run --project %S/../../src/FunLangCompiler.Cli/FunLangCompiler.Cli.fsproj -- %input -o $OUTBIN && $OUTBIN; echo $?; rm -f $OUTBIN'
// --- Input:
let isPos (x : int) : bool = x > 0
let fmixed (x : int) y (z : bool) : int = if z then x else y
let rec fact (n : int) : int = if n <= 1 then 1 else n * fact (n - 1)
let _ = println (to_string (isPos 5))
let _ = println (to_string (isPos (-3)))
let _ = println (to_string (fmixed 10 20 true))
let _ = println (to_string (fact 5))
// --- Output:
true
false
10
120
0
