// Test: Angle bracket generic type declarations (FunLang v8.0)
// --- Command: bash -c 'OUTBIN=$(mktemp /tmp/fnc_XXXXXX) && dotnet run --project %S/../../src/FunLangCompiler.Cli/FunLangCompiler.Cli.fsproj -- %input -o $OUTBIN && $OUTBIN; echo $?; rm -f $OUTBIN'
// --- Input:
type Box<'a> = MkBox of 'a
type Result<'a> = Ok of 'a | Err of string
let unbox (b : Box<int>) : int = match b with | MkBox v -> v
let extract (r : Result<int>) : int = match r with | Ok v -> v | Err _ -> 0
let _ = println (to_string (unbox (MkBox 99)))
let _ = println (to_string (extract (Ok 42)))
let _ = println (to_string (extract (Err "bad")))
// --- Output:
99
42
0
0
