let rec fold f = fun acc -> fun xs -> match xs with | [] -> acc | h :: t -> fold f (f acc h) t in let rec scan f acc xs = match xs with | [] -> [acc] | h :: t -> acc :: scan f (f acc h) t in let rec pairwise xs = match xs with | a :: b :: rest -> (a, b) :: pairwise (b :: rest) | _ -> [] in let rec map f = fun xs -> match xs with | [] -> [] | h :: t -> f h :: map f t in let sumBy f xs = fold (fun acc -> fun x -> acc + f x) 0 xs in let sum xs = fold (fun acc -> fun x -> acc + x) 0 xs in let rec printList xs = match xs with | [] -> 0 | h :: t -> let _ = println (to_string h) in printList t in let _ = printList (scan (fun a -> fun b -> a + b) 0 [1; 2; 3]) in let pairs = pairwise [1; 2; 3; 4] in let pairSums = map (fun p -> match p with | (a, b) -> a + b) pairs in let _ = printList pairSums in let _ = println (to_string (sumBy (fun x -> x * x) [1; 2; 3])) in let _ = println (to_string (sum [10; 20; 30])) in 0
