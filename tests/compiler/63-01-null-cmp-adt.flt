// Test: Issue #2 — null comparison in ADT match arm (list = [] after Ok extraction)
// --- Command: bash -c 'OUTBIN=$(mktemp /tmp/fnc_XXXXXX) && dotnet run --project %S/../../src/FunLangCompiler.Cli/FunLangCompiler.Cli.fsproj -- %input -o $OUTBIN && $OUTBIN; echo $?; rm -f $OUTBIN'
// --- Input:
type Res 'a =
    | Ok of 'a
    | Err of string

let getData () =
    Ok []

let main =
    match getData () with
    | Err e -> printfn "error: %s" e
    | Ok cases ->
        if cases = [] then
            println "EMPTY"
        else
            println "HAS DATA"
// --- Output:
EMPTY
0
